{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["packages/shared-config/tsconfig.base.json"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "inputs": ["src/**", "tsconfig.json", "package.json"]
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": [],
      "inputs": ["src/**", "tsconfig.json", "package.json", "vitest.config.*"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": [],
      "inputs": ["src/**", "tsconfig.json", "package.json"]
    },
    "//#test:scripts": {
      "outputs": [],
      "inputs": ["scripts/**"]
    }
  }
}
